{
  "name": "wa-warmer",
  "version": "1.13.0",
  "description": "Portable WhatsApp account warmer with embedded GOWA engine",
  "author": "WA Warmer",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "fetch-gowa": "node scripts/fetch-gowa.mjs",
    "build-gowa": "node scripts/build-gowa.mjs",
    "seed-messages": "node scripts/seed-messages.mjs",
    "icon": "node scripts/generate-icon.mjs",
    "prestart": "node scripts/ensure-assets.mjs",
    "start": "node src/server/server.js",
    "preserver": "node scripts/ensure-assets.mjs",
    "server": "node src/server/server.js",
    "start:electron": "electron .",
    "prebuild": "node scripts/ensure-assets.mjs",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --x64 --arm64 --publish never",
    "build:win": "electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^9.3.0",
    "@fastify/websocket": "^11.3.0",
    "fastify": "^5.10.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
